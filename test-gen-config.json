{
    "enabled": "true",
    "increase-coverage": {
      "project-name": "rails-test-project",
      "target-branches": [
        "master"
      ],
      "test-env-docker-stage": "test",
      "build-test-env-docker-stage-script-path": "tool/build-test-env-docker-stage.sh",
      "test-files-folders": [
        "test/models"
      ],
      "source-test-file-paths": [
        {
          "source-file-path": "app/models/user.rb",
          "test-file-path": "test/models/user_test.rb"
        }
      ],
      "test-command": "bundle exec rails test",
      "coverage-type": "lcov",
      "code-coverage-report-path": "coverage/lcov.info",
      "desired-coverage": 100,
      "max-iterations": 1,
      "max-number-of-test-cases": 6,
      "mode": "dry_run"
    }
}